# Server Configuration
# Port on which the Express server will listen (e.g., 3000)
PORT=

# Authentication Secret
# Secret key used for signing JWT tokens
JWT_SECRET=

# Supabase Configuration
# Required: The project URL for Supabase (Must start with https://)
SUPABASE_URL=

# Required: The public anonymous API key
SUPABASE_ANON_KEY=

# Required: The secret service role API key (Keep this secure!)
SUPABASE_SERVICE_ROLE_KEY=
